{
  "name": "canvas-mcp-server",
  "version": "1.0.1",
  "description": "MCP server for Dynamic UI Canvas API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:combined": "node start.js",
    "test": "vitest",
    "test:run": "vitest --run"
  },
  "keywords": [
    "mcp",
    "canvas",
    "dynamic-ui",
    "model-context-protocol"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "vitest": "^1.2.0"
  }
}
